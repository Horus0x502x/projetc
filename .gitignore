# Artifacts lourds — non versionnés
traces/*
!traces/.gitkeep
dumps/*
!dumps/.gitkeep

# Refs (clones upstream) — gérés à part, pas committés
refs/*
!refs/.gitkeep

# Ghidra
# Les projets analyzes (.rep/.gpr) peuvent atteindre des centaines de Mo
# et sont reproductibles via : ~/tools/ghidra/support/analyzeHeadless ...
# On commite seulement le log + les findings exports.
ghidra/*-project/
ghidra/*.lock
ghidra/*.lock~
ghidra/*.bak
ghidra/.ghidra/

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# Éditeurs
*.swp
*.swo
*~
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Crash dumps locaux
*.dmp

# Frida outputs bruts
*.frida-trace
